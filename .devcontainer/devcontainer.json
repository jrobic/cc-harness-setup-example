{
  // Thin devcontainer wrapper over docker/Dockerfile.
  // No build logic is duplicated here (R12.2).
  "name": "harness-setup-example",
  "build": {
    "context": "..",
    "dockerfile": "../docker/Dockerfile"
  },
  "remoteUser": "harness",
  "containerEnv": {
    // HARNESS_HOME isolates engine writes to the container — the host's
    // ~/.claude is never mounted or touched.
    "HARNESS_HOME": "/home/harness/.claude-harness-demo"
    // ANTHROPIC_API_KEY: set in your local .env or devcontainer secrets if
    // you want to run the full live Claude Code CLI flow inside the container.
    // Never commit this value.
  },
  "postCreateCommand": "echo 'Harness devcontainer ready. Run: bun test'",
  "features": {}
}
