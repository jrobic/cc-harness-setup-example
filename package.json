{
  "name": "jrobic-cc-harness-setup-example",
  "version": "0.1.0",
  "description": "Example harness for Claude Code: deny list, context import, and team tooling in one command.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrobic/cc-harness-setup-example.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "test": "bun test",
    "build:hardened": "bun run scripts/build-hardened.ts",
    "engine:check": "bun run plugins/jrobic-cc-harness-setup-example/scripts/harness-setup.ts check",
    "engine:apply": "bun run plugins/jrobic-cc-harness-setup-example/scripts/harness-setup.ts apply",
    "release:dry": "semantic-release --dry-run --no-ci",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "24",
    "dprint": "^0.54.0",
    "lefthook": "^2.1.9",
    "oxlint": "^1.68.0",
    "semantic-release": "^25.0.5"
  }
}
